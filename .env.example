# Google Places API key — powers restaurant search (search-places / get-place).
# https://developers.google.com/maps/documentation/places/web-service/overview
GOOGLE_PLACES_API_KEY=

# Tessie — sets the paired Tesla's navigation when a nom is selected.
# The API key + VIN live in a Secrets Manager secret (JSON: TESSIE_API_KEY,
# TESLA_VIN); put its ARN here. Create with:
#   aws secretsmanager create-secret --name jpc-noms/tessie \
#     --secret-string '{"TESSIE_API_KEY":"...","TESLA_VIN":"..."}'
TESSIE_SECRET_ARN=
