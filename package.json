{
  "name": "jpc-noms",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck:amplify": "tsc --noEmit -p amplify/tsconfig.json",
    "build": "tsc && npm run typecheck:amplify && vite build",
    "preview": "vite preview",
    "prod-config": "node scripts/prod-config.mjs",
    "e2e-config": "ampx generate outputs --stack amplify-jpcnoms-xss-sandbox-c38bb97e0e --profile personal",
    "gen:icons": "node scripts/gen-app-icons.mjs",
    "seed": "tsx amplify/seed/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bddgen && playwright test",
    "crap": "node scripts/crap-check.mjs",
    "check:lines": "node scripts/check-file-lines.mjs",
    "check:features": "node scripts/check-feature-coverage.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "npm run lint && npm run format:check && npm run check:lines && npm run check:features && npm run test:coverage && npm run crap && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@ionic/react": "^8.5.0",
    "@ionic/react-router": "^8.5.0",
    "@tanstack/react-query": "^5.101.2",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "aws-amplify": "^6.18.0",
    "ionicons": "^7.4.0",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.23.0",
    "@aws-amplify/backend-cli": "^1.8.3",
    "@aws-sdk/client-dynamodb": "^3.1079.0",
    "@aws-sdk/client-sns": "^3.1079.0",
    "@aws-sdk/lib-dynamodb": "^3.1079.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.1",
    "@vitest/coverage-istanbul": "^0.34.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^17.0.8",
    "playwright-bdd": "^9.2.0",
    "sharp": "^0.35.3",
    "terser": "^5.4.0",
    "tsx": "^4.22.5",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^5.0.0",
    "vitest": "^0.34.6"
  },
  "description": "Collaborative restaurant nominations for two — search, save to rotation, nominate together, and let the winner set your Tesla's navigation."
}
